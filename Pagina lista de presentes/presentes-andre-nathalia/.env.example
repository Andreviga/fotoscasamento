# ====== SITE ======
PORT=3000

# ====== PIX (direto para sua conta) ======
PIX_KEY=SUA_CHAVE_PIX_AQUI
PIX_MERCHANT_NAME=ANDRE E NATHALIA
PIX_MERCHANT_CITY=SAO BERNARDO DO CAMPO

# ====== ADMIN (painel /admin) ======
ADMIN_PASSWORD=coloque_uma_senha_forte

# ====== CARTAO (ASAAS) ======
ASAAS_API_KEY=sua_api_key_asaas
ASAAS_ENV=sandbox
# ASAAS_ENV=prod

# ====== PIX DINÂMICO (BTG) ======
# URL completa do endpoint BTG para criar cobrança Pix
BTG_PIX_CREATE_URL=https://developers.empresas.btgpactual.com/SEU_ENDPOINT
# Token de autenticação (se aplicável)
BTG_PIX_AUTH_TOKEN=seu_token
# Header e prefixo para autenticação (opcional)
BTG_PIX_AUTH_HEADER=Authorization
BTG_PIX_AUTH_PREFIX=Bearer

# URL pública do seu site (para voltar depois do pagamento)
PUBLIC_BASE_URL=http://localhost:3000
